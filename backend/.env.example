# Mosquitto broker (raw MQTT, port 1883). The Python paho-mqtt client uses TCP, not WebSocket.
MQTT_HOST=gps-mqtt-ezza123.southeastasia.azurecontainer.io
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Topics
MQTT_TELEMETRY_TOPIC=gps/+/telemetry
MQTT_ANOMALY_TOPIC_FMT=gps/{deviceId}/anomaly

# Rule thresholds — all tunable
SPEED_LIMIT_KMH=120
STATIONARY_MINUTES=30
JUMP_DISTANCE_KM=1.0
JUMP_TIME_SECONDS=10

# Isolation Forest parameters
ISOFOREST_N_ESTIMATORS=100
ISOFOREST_CONTAMINATION=0.05
ISOFOREST_MAX_SAMPLES=64

# Buffer / training cadence
BUFFER_SIZE=200
MIN_READINGS_BEFORE_ML=30
RETRAIN_EVERY=50
